            <div class="skill-pill"><i class="fab fa-docker"></i> Docker</div>
            <div class="skill-pill"><i class="fab fa-aws"></i> AWS</div>
            <div class="skill-pill"><i class="fab fa-linux"></i> Linux</div>
            <div class="skill-pill">Hostinger</div>
          </div>
        </div>

        <div class="skill-cat card soft-skills">
          <h3 class="sc-title"><span class="accent-text">06</span> Aptitudes</h3>
          <div class="skill-tags">
            <div class="skill-pill soft">Organizado</div>
            <div class="skill-pill soft">Aprendizaje Rápido</div>
