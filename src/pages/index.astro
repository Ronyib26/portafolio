---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---
<Layout>
  <div class="bg-blobs">
    <span></span><span></span><span></span>
  </div>

  <!-- ===== SIDEBAR ===== -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-inner">
      <div class="profile-block">
        <div class="avatar-ring">
          <img src="/portafolio/images/perfil.jpeg" alt="Rony Lopez" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
        </div>
        <h1 class="profile-name">Rony Lopez</h1>
        <p class="profile-role"><span class="typing-text">Full-Stack Developer</span></p>
        <div class="status-badge">
          <span class="status-dot"></span>
          Disponible para proyectos
        </div>
      </div>

      <div class="contact-block">
        <div class="contact-item">
          <div class="ci-icon"><i class="fa fa-envelope"></i></div>
          <div class="ci-content">
            <span class="ci-label">Email</span>
            <a href="mailto:ronyinvo@icloud.com" class="ci-value">ronyinvo@icloud.com</a>
          </div>
        </div>
        <div class="contact-item">
          <div class="ci-icon"><i class="fa fa-phone"></i></div>
          <div class="ci-content">
            <span class="ci-label">Teléfono</span>
            <a href="tel:+50255795858" class="ci-value">+502 5579-5858</a>
          </div>
        </div>
        <div class="contact-item">
          <div class="ci-icon"><i class="fa fa-map-marker-alt"></i></div>
          <div class="ci-content">
            <span class="ci-label">Ubicación</span>
            <span class="ci-value">Quetzaltenango, GT</span>
          </div>
        </div>
        <div class="contact-item">
          <div class="ci-icon"><i class="fa fa-calendar"></i></div>
          <div class="ci-content">
            <span class="ci-label">Nacimiento</span>
            <span class="ci-value">10 Dic, 1994</span>
          </div>
        </div>
      </div>

      <div class="social-block">
        <a href="https://github.com/Ronyib26" target="_blank" rel="noopener" class="social-btn" title="GitHub">
          <i class="fab fa-github"></i>
        </a>
        <a href="https://www.linkedin.com/in/rony-lopez-613377351/" target="_blank" rel="noopener" class="social-btn" title="LinkedIn">
          <i class="fab fa-linkedin-in"></i>
        </a>
        <a href="mailto:ronyinvo@icloud.com" class="social-btn" title="Email">
          <i class="fa fa-envelope"></i>
        </a>
      </div>

      <nav class="sidebar-nav">
        <a href="#about" class="snav-link active">Sobre mí</a>
        <a href="#experience" class="snav-link">Experiencia</a>
        <a href="#skills" class="snav-link">Habilidades</a>
        <a href="#projects" class="snav-link">Proyectos</a>
        <a href="#contact" class="snav-link">Contacto</a>
      </nav>
    </div>
  </aside>

  <!-- TOPBAR mobile -->
  <header class="topbar">
    <div class="topbar-brand">
      <span class="mono-tag">&lt;</span>RL<span class="mono-tag">/&gt;</span>
    </div>
    <button class="hamburger" id="hamburger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </header>

  <main class="main-content">

    <!-- ACERCA DE MI -->
    <section id="about" class="page-section">
      <div class="hero-block fade-in">
        <h2 class="hero-heading">Hola, soy <span class="accent-text">Rony Lopez</span> 👋</h2>
        <p class="hero-sub">Desarrollador Full-Stack con más de 2 año de experiencia construyendo aplicaciones web escalables y robustas. Especializado en React, Node.js, TypeScript, Laravel y arquitecturas cloud.</p>
        <p class="hero-text">He trabajado con organizaciones como <strong>FAFG</strong>, <strong>ISACA Guatemala</strong> y <strong>Pastoral Social Cáritas</strong>, entregando sistemas enterprise que soportan 500+ usuarios concurrentes.</p>
        <div class="hero-actions">
          <a href="#projects" class="btn-primary">Ver Proyectos <i class="fa fa-arrow-right"></i></a>
          <a href="#contact" class="btn-outline">Contáctame</a>
        </div>
      </div>

      <div class="stats-row">
        <div class="stat-item card fade-in fade-in-delay-1">
          <span class="stat-number accent-text">4+</span>
          <span class="stat-label">Proyectos Enterprise</span>
        </div>
        <div class="stat-item card fade-in fade-in-delay-2">
          <span class="stat-number accent-text">500+</span>
          <span class="stat-label">Usuarios Concurrentes</span>
        </div>
        <div class="stat-item card fade-in fade-in-delay-3">
          <span class="stat-number accent-text">10+</span>
          <span class="stat-label">Tecnologías</span>
        </div>
        <div class="stat-item card fade-in fade-in-delay-4">
          <span class="stat-number accent-text">&lt;200ms</span>
          <span class="stat-label">Tiempo de Respuesta</span>
        </div>
      </div>

      <div class="services-block">
        <h3 class="section-title">¿Qué ofrezco?</h3>
        <div class="services-grid">
          <div class="service-card card">
            <div class="sc-icon"><i class="fa fa-code"></i></div>
            <div><h4>Desarrollo Frontend</h4><p>Interfaces modernas y responsivas con React, TypeScript, Tailwind CSS y Astro.</p></div>
          </div>
          <div class="service-card card">
            <div class="sc-icon"><i class="fa fa-server"></i></div>
            <div><h4>Desarrollo Backend</h4><p>APIs RESTful con Node.js, Express y Laravel. Autenticación JWT y sistemas de colas.</p></div>
          </div>
          <div class="service-card card">
            <div class="sc-icon"><i class="fa fa-database"></i></div>
            <div><h4>Bases de Datos</h4><p>Diseño y optimización de MySQL, PostgreSQL y Oracle con índices escalables.</p></div>
          </div>
          <div class="service-card card">
            <div class="sc-icon"><i class="fab fa-docker"></i></div>
            <div><h4>DevOps & Cloud</h4><p>Despliegue en AWS, Hostinger, Docker, GitHub Actions. Sistemas production-ready.</p></div>
          </div>
        </div>
      </div>
    </section>

    <!-- EXPERIENCIA -->
    <section id="experience" class="page-section">
      <div class="section-label">// trayectoria</div>
      <h2 class="section-title">Experiencia Técnica</h2>
      <div class="timeline">

        <div class="tl-item">
          <div class="tl-dot"></div>
          <div class="tl-content card">
            <div class="tl-header">
              <div><h3 class="tl-title">Desarrollador Web</h3><span class="tl-company">Cooperativa DEICOM</span></div>
              <div class="tl-stack"><span class="tag">Astro</span><span class="tag">Tailwind</span><span class="tag">TypeScript</span></div>
            </div>
            <ul class="tl-list">
              <li>Desarrollé Landing Page de alto rendimiento con tiempos de carga mínimos y arquitectura de componentes reutilizables.</li>
              <li>Implementé identidad visual corporativa basada en manuales de marca.</li>
              <li>Optimicé SEO técnico y responsividad para todos los dispositivos.</li>
            </ul>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-dot"></div>
          <div class="tl-content card">
            <div class="tl-header">
              <div><h3 class="tl-title">Sistema de Gestión de Eventos</h3><span class="tl-company">ISACA Guatemala</span></div>
              <div class="tl-stack"><span class="tag">Laravel</span><span class="tag">PHP</span><span class="tag">MySQL</span><span class="tag">QR Codes</span></div>
            </div>
            <ul class="tl-list">
              <li>Sistema integral con registro público, control de asistencia en tablets y generación automatizada de diplomas.</li>
              <li>Arquitectura multi-guard para autenticación simultánea y colas para procesamiento asíncrono de emails masivos.</li>
              <li>Optimizaciones que soportaron <strong>500+ usuarios concurrentes</strong> con dashboard de filtros avanzados.</li>
              <li>QR codes dinámicos, generación automática de PDFs y emails con reintentos automáticos.</li>
            </ul>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-dot"></div>
          <div class="tl-content card">
            <div class="tl-header">
              <div><h3 class="tl-title">Plataforma de Gestión de Proyectos Sociales</h3><span class="tl-company">Pastoral Social Cáritas</span></div>
              <div class="tl-stack"><span class="tag">React</span><span class="tag">Node.js</span><span class="tag">TypeScript</span><span class="tag">PostgreSQL</span><span class="tag">Docker</span></div>
            </div>
            <ul class="tl-list">
              <li>Clean Architecture con <strong>65+ endpoints REST</strong> y autenticación JWT.</li>
              <li>Sistema de permisos granulares, CRUDs completos y vistas Kanban interactivas.</li>
              <li>Generación dinámica de PDFs con Puppeteer, dashboard analítico y exportación de reportes.</li>
              <li>Flujo de aprobaciones automatizado con notificaciones en tiempo real.</li>
            </ul>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-dot accent-dot"></div>
          <div class="tl-content card">
            <div class="tl-header">
              <div><h3 class="tl-title">Sistema Enterprise de Gestión</h3><span class="tl-company">FAFG</span></div>
              <div class="tl-stack"><span class="tag">ScriptCase</span><span class="tag">PHP</span><span class="tag">MySQL</span></div>
            </div>
            <ul class="tl-list">
              <li>APIs REST con rate limiting y cache multicapa inteligente.</li>
              <li>Kanban enterprise con drag & drop y organización automática de documentos.</li>
              <li><strong>25+ índices escalables</strong> para optimización de queries complejas.</li>
              <li>Tiempo de respuesta &lt;200ms con cientos de usuarios concurrentes.</li>
            </ul>
          </div>
        </div>

      </div>

      <div style="margin-top: 60px;">
        <div class="section-label">// formación</div>
        <h3 class="section-title">Educación & Certificaciones</h3>
        <div class="edu-grid">
          <div class="edu-item card">
            <div class="edu-icon"><i class="fa fa-graduation-cap"></i></div>
            <div><h4>Ingeniería en Sistemas</h4><p class="edu-org">Universidad Mariano Gálvez de Guatemala</p><span class="tag">2020 — Presente</span></div>
          </div>
          <div class="edu-item card">
            <div class="edu-icon cert-icon"><i class="fa fa-certificate"></i></div>
            <div><h4>Web Dev Essentials</h4><p class="edu-org">Certificación OpenEDG HTML/CSS</p><span class="tag">2025</span></div>
          </div>
          <div class="edu-item card">
            <div class="edu-icon cert-icon"><i class="fa fa-certificate"></i></div>
            <div><h4>JavaScript Essentials</h4><p class="edu-org">Certificación OpenEDG</p><span class="tag">2025</span></div>
          </div>
          <div class="edu-item card">
            <div class="edu-icon cert-icon"><i class="fa fa-network-wired"></i></div>
            <div><h4>CISCO CCNA</h4><p class="edu-org">Introducción a las Redes</p><span class="tag">2025</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- HABILIDADES -->
    <section id="skills" class="page-section">
      <div class="section-label">// tecnologías</div>
      <h2 class="section-title">Stack Técnico</h2>
      <div class="skills-categories">
        <div class="skill-cat card">
          <h3 class="sc-title"><span class="accent-text">01</span> Lenguajes</h3>
          <div class="skill-tags">
            <div class="skill-pill"><i class="fab fa-js"></i> JavaScript</div>
            <div class="skill-pill"><i class="fab fa-js"></i> TypeScript</div>
            <div class="skill-pill"><i class="fab fa-php"></i> PHP</div>
            <div class="skill-pill"><i class="fab fa-python"></i> Python</div>
            <div class="skill-pill">C++</div>
          </div>
        </div>
        <div class="skill-cat card">
          <h3 class="sc-title"><span class="accent-text">02</span> Frontend</h3>
          <div class="skill-tags">
            <div class="skill-pill"><i class="fab fa-react"></i> React</div>
            <div class="skill-pill"><i class="fab fa-html5"></i> HTML5 / CSS3</div>
            <div class="skill-pill">Tailwind CSS</div>
            <div class="skill-pill">Astro</div>
            <div class="skill-pill"><i class="fab fa-bootstrap"></i> Bootstrap</div>
          </div>
        </div>
        <div class="skill-cat card">
          <h3 class="sc-title"><span class="accent-text">03</span> Backend</h3>
          <div class="skill-tags">
            <div class="skill-pill"><i class="fab fa-node-js"></i> Node.js</div>
            <div class="skill-pill">Express.js</div>
            <div class="skill-pill">Laravel</div>
            <div class="skill-pill">Prisma ORM</div>
            <div class="skill-pill">REST APIs</div>
          </div>
        </div>
        <div class="skill-cat card">
          <h3 class="sc-title"><span class="accent-text">04</span> Bases de Datos</h3>
          <div class="skill-tags">
            <div class="skill-pill"><i class="fa fa-database"></i> MySQL</div>
            <div class="skill-pill">PostgreSQL</div>
            <div class="skill-pill">Oracle SQL</div>
          </div>
        </div>
        <div class="skill-cat card">
          <h3 class="sc-title"><span class="accent-text">05</span> DevOps & Tools</h3>
          <div class="skill-tags">
            <div class="skill-pill"><i class="fab fa-git-alt"></i> Git / GitHub</div>
            <div class="skill-pill"><i class="fab fa-docker"></i> Docker</div>
            <div class="skill-pill"><i class="fab fa-aws"></i> AWS</div>
            <div class="skill-pill"><i class="fab fa-linux"></i> Linux</div>
            <div class="skill-pill">Hostinger</div>
          </div>
        </div>
        <div class="skill-cat card">
          <h3 class="sc-title"><span class="accent-text">06</span> Aptitudes</h3>
          <div class="skill-tags">
            <div class="skill-pill soft">Organizado</div>
            <div class="skill-pill soft">Aprendizaje Rápido</div>
            <div class="skill-pill soft">Pensamiento Crítico</div>
            <div class="skill-pill soft">Relaciones Interpersonales</div>
          </div>
        </div>
      </div>
    </section>

    <!-- PROYECTOS -->
    <section id="projects" class="page-section">
      <div class="section-label">// portafolio</div>
      <h2 class="section-title">Proyectos Destacados</h2>

      <div class="projects-grid">

        <div class="proj-card card">
          <div class="proj-img-wrap">
            <img src="/portafolio/images/deicom-1.png" alt="Landing Page Cooperativa DEICOM" loading="lazy" />
            <div class="proj-img-overlay"></div>
          </div>
          <div class="proj-body">
            <div class="proj-header">
              <div class="proj-icon"><i class="fa fa-rocket"></i></div>
              <div class="proj-links">
                <a href="https://github.com/Ronyib26" target="_blank" class="proj-link"><i class="fab fa-github"></i></a>
              </div>
            </div>
            <h3 class="proj-title">Landing Page — Cooperativa DEICOM</h3>
            <p class="proj-desc">Landing page de alto rendimiento con identidad visual corporativa, SEO técnico optimizado y arquitectura de componentes reutilizables.</p>
            <div class="proj-tech"><span class="tag">Astro</span><span class="tag">Tailwind CSS</span><span class="tag">TypeScript</span></div>
            <div class="proj-highlight"><i class="fa fa-bolt accent-text"></i><span>Performance 95+ · Mobile-first · SEO</span></div>
          </div>
        </div>

        <div class="proj-card card featured">
          <div class="proj-featured-badge">Destacado</div>
          <div class="proj-img-wrap">
            <img src="/portafolio/images/deicom-2.png" alt="Simulador Financiero DEICOM" loading="lazy" />
            <div class="proj-img-overlay"></div>
          </div>
          <div class="proj-body">
            <div class="proj-header">
              <div class="proj-icon"><i class="fa fa-calculator"></i></div>
              <div class="proj-links">
                <a href="https://github.com/Ronyib26" target="_blank" class="proj-link"><i class="fab fa-github"></i></a>
              </div>
            </div>
            <h3 class="proj-title">Simulador Financiero — DEICOM</h3>
            <p class="proj-desc">Herramienta interactiva de cotización para inversiones a plazo fijo y créditos. Cálculo en tiempo real integrado en la landing page.</p>
            <div class="proj-tech"><span class="tag">Astro</span><span class="tag">JavaScript</span><span class="tag">Tailwind</span></div>
            <div class="proj-highlight"><i class="fa fa-bolt accent-text"></i><span>UI interactiva · Cálculo tiempo real</span></div>
          </div>
        </div>

        <div class="proj-card card">
          <div class="proj-img-wrap">
            <img src="/portafolio/images/isaca-1.png" alt="Panel Admin ISACA Guatemala" loading="lazy" />
            <div class="proj-img-overlay"></div>
          </div>
          <div class="proj-body">
            <div class="proj-header">
              <div class="proj-icon"><i class="fa fa-users-cog"></i></div>
              <div class="proj-links">
                <a href="https://github.com/Ronyib26" target="_blank" class="proj-link"><i class="fab fa-github"></i></a>
              </div>
            </div>
            <h3 class="proj-title">Panel Admin — ISACA Summit 2025</h3>
            <p class="proj-desc">Dashboard de administración con gestión de registros, validación de pagos, filtros avanzados y exportación CSV para 500+ participantes.</p>
            <div class="proj-tech"><span class="tag">Laravel</span><span class="tag">PHP</span><span class="tag">MySQL</span><span class="tag">JavaScript</span></div>
            <div class="proj-highlight"><i class="fa fa-bolt accent-text"></i><span>500+ usuarios · Export CSV · Multi-guard</span></div>
          </div>
        </div>

        <div class="proj-card card">
          <div class="proj-img-wrap">
            <img src="/portafolio/images/isaca-2.png" alt="Control Asistencia QR ISACA" loading="lazy" />
            <div class="proj-img-overlay"></div>
          </div>
          <div class="proj-body">
            <div class="proj-header">
              <div class="proj-icon"><i class="fa fa-qrcode"></i></div>
              <div class="proj-links">
                <a href="https://github.com/Ronyib26" target="_blank" class="proj-link"><i class="fab fa-github"></i></a>
              </div>
            </div>
            <h3 class="proj-title">Control de Asistencia QR — ISACA</h3>
            <p class="proj-desc">Sistema de registro con escaneo QR en tablets para eventos en vivo. Validación de tickets y generación automática de diplomas en PDF.</p>
            <div class="proj-tech"><span class="tag">Laravel</span><span class="tag">QR Codes</span><span class="tag">PDF Generation</span></div>
            <div class="proj-highlight"><i class="fa fa-bolt accent-text"></i><span>QR dinámicos · Diplomas automáticos</span></div>
          </div>
        </div>

        <div class="proj-card card featured">
          <div class="proj-featured-badge">Enterprise</div>
          <div class="proj-img-wrap">
            <img src="/portafolio/images/caritas-1.png" alt="Dashboard Pastoral Social Cáritas" loading="lazy" />
            <div class="proj-img-overlay"></div>
          </div>
          <div class="proj-body">
            <div class="proj-header">
              <div class="proj-icon"><i class="fa fa-chart-bar"></i></div>
              <div class="proj-links">
                <a href="https://github.com/Ronyib26" target="_blank" class="proj-link"><i class="fab fa-github"></i></a>
              </div>
            </div>
            <h3 class="proj-title">Dashboard de Proyectos — Cáritas</h3>
            <p class="proj-desc">Dashboard enterprise con gestión de programas sociales, seguimiento de indicadores y proyectos activos por unidad organizacional.</p>
            <div class="proj-tech"><span class="tag">React</span><span class="tag">Node.js</span><span class="tag">TypeScript</span><span class="tag">PostgreSQL</span></div>
            <div class="proj-highlight"><i class="fa fa-bolt accent-text"></i><span>65+ endpoints · JWT · Clean Architecture</span></div>
          </div>
        </div>

        <div class="proj-card card">
          <div class="proj-img-wrap">
            <img src="/portafolio/images/caritas-2.png" alt="Gestión Indicadores Cáritas" loading="lazy" />
            <div class="proj-img-overlay"></div>
          </div>
          <div class="proj-body">
            <div class="proj-header">
              <div class="proj-icon"><i class="fa fa-tasks"></i></div>
              <div class="proj-links">
                <a href="https://github.com/Ronyib26" target="_blank" class="proj-link"><i class="fab fa-github"></i></a>
              </div>
            </div>
            <h3 class="proj-title">Gestión de Indicadores — Cáritas</h3>
            <p class="proj-desc">Vista de indicadores y actividades por componente. Tracking de metas, actividades con fechas y asignación de equipos por proyecto.</p>
            <div class="proj-tech"><span class="tag">React</span><span class="tag">Docker</span><span class="tag">Prisma ORM</span><span class="tag">Tailwind</span></div>
            <div class="proj-highlight"><i class="fa fa-bolt accent-text"></i><span>Notificaciones real-time · Puppeteer PDFs</span></div>
          </div>
        </div>

      </div>

      <div class="github-cta">
        <p>¿Quieres ver más código?</p>
        <a href="https://github.com/Ronyib26" target="_blank" rel="noopener" class="btn-outline">
          <i class="fab fa-github"></i> Ver GitHub
        </a>
      </div>
    </section>

    <!-- CONTACTO -->
    <section id="contact" class="page-section">
      <div class="section-label">// contáctame</div>
      <h2 class="section-title">Trabajemos Juntos</h2>
      <div class="contact-layout">
        <div>
          <p class="contact-intro">Estoy disponible para proyectos freelance, oportunidades laborales o simplemente charlar sobre tecnología. ¡Escríbeme!</p>
          <div class="contact-methods">
            <a href="mailto:ronyinvo@icloud.com" class="cm-item card">
              <div class="cm-icon"><i class="fa fa-envelope"></i></div>
              <div><span class="cm-label">Email directo</span><span class="cm-value">ronyinvo@icloud.com</span></div>
            </a>
            <a href="https://www.linkedin.com/in/rony-lopez-613377351/" target="_blank" class="cm-item card">
              <div class="cm-icon linkedin-ic"><i class="fab fa-linkedin-in"></i></div>
              <div><span class="cm-label">LinkedIn</span><span class="cm-value">linkedin.com/in/RonyLopez</span></div>
            </a>
            <a href="https://github.com/Ronyib26" target="_blank" class="cm-item card">
              <div class="cm-icon github-ic"><i class="fab fa-github"></i></div>
              <div><span class="cm-label">GitHub</span><span class="cm-value">github.com/Ronyib26</span></div>
            </a>
          </div>
        </div>

        <form class="contact-form card" id="contactForm">
          <h3>Envíame un mensaje</h3>
          <div class="form-group">
            <label for="name">Nombre completo</label>
            <input type="text" id="name" name="name" placeholder="Tu nombre" required />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="tu@email.com" required />
          </div>
          <div class="form-group">
            <label for="subject">Asunto</label>
            <input type="text" id="subject" name="subject" placeholder="¿De qué se trata?" />
          </div>
          <div class="form-group">
            <label for="message">Mensaje</label>
            <textarea id="message" name="message" rows="5" placeholder="Cuéntame sobre tu proyecto..." required></textarea>
          </div>
          <button type="submit" class="btn-primary submit-btn">
            Enviar Mensaje <i class="fa fa-paper-plane"></i>
          </button>
          <p class="form-note">* Este formulario abre tu cliente de email.</p>
        </form>
      </div>
    </section>

  </main>

  <footer class="footer">
    <p>Diseñado y construido con <span class="accent-text">♥</span> por <strong>Rony Lopez</strong> · Hecho con <span class="accent-text">Astro</span></p>
  </footer> 

</Layout>

<script>
  document.getElementById('hamburger')?.addEventListener('click', () => {
    document.getElementById('sidebar')?.classList.toggle('open');
  });

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        document.querySelectorAll('.snav-link').forEach(l => l.classList.remove('active'));
        document.querySelector(`.snav-link[href="#${entry.target.id}"]`)?.classList.add('active');
      }
    });
  }, { threshold: 0.3 });
  document.querySelectorAll('.page-section').forEach(s => observer.observe(s));

  const fadeObs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        (entry.target as HTMLElement).style.opacity = '1';
        (entry.target as HTMLElement).style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('.card, .tl-item, .edu-item').forEach(el => {
    (el as HTMLElement).style.opacity = '0';
    (el as HTMLElement).style.transform = 'translateY(16px)';
    (el as HTMLElement).style.transition = 'opacity 0.5s ease, transform 0.5s ease';
    fadeObs.observe(el);
  });

  document.getElementById('contactForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const name = (document.getElementById('name') as HTMLInputElement).value;
    const subject = (document.getElementById('subject') as HTMLInputElement).value || 'Contacto desde Portafolio';
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const message = (document.getElementById('message') as HTMLTextAreaElement).value;
    window.open(`mailto:ronyinvo@icloud.com?subject=${encodeURIComponent(subject)}&body=Hola Rony,%0A%0AMi nombre es ${encodeURIComponent(name)} (${encodeURIComponent(email)})%0A%0A${encodeURIComponent(message)}`);
  });
</script>
