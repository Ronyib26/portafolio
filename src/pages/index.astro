            <div class="skill-pill"><i class="fab fa-bootstrap"></i> Bootstrap</div>
          </div>
        </div>

        <div class="skill-cat card">
          <h3 class="sc-title"><span class="accent-text">03</span> Backend</h3>
          <div class="skill-tags">
            <div class="skill-pill"><i class="fab fa-node-js"></i> Node.js</div>
            <div class="skill-pill">Express.js</div>
            <div class="skill-pill">Laravel</div>
