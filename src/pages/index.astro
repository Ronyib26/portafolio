---
import Layout from '../layouts/Layout.astro';
---
<Layout>
  <div class="bg-blobs">
    <span></span><span></span><span></span>
  </div>

  <!-- ===== SIDEBAR ===== -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-inner">

      <!-- Profile -->
      <div class="profile-block">
        <div class="avatar-ring">
          <div class="avatar-placeholder">
            <span>RL</span>
          </div>
        </div>
        <h1 class="profile-name">Rony Lopez</h1>
        <p class="profile-role">
          <span class="typing-text">Full-Stack Developer</span>
        </p>
        <div class="status-badge">
          <span class="status-dot"></span>
          Disponible para proyectos
        </div>
      </div>

      <!-- Contact Info -->
      <div class="contact-block">
        <div class="contact-item">
          <div class="ci-icon"><i class="fa fa-envelope"></i></div>
          <div class="ci-content">
            <span class="ci-label">Email</span>
            <a href="mailto:ronyinvo@icloud.com" class="ci-value">ronyinvo@icloud.com</a>
          </div>
        </div>
        <div class="contact-item">
          <div class="ci-icon"><i class="fa fa-phone"></i></div>
          <div class="ci-content">
            <span class="ci-label">Teléfono</span>
            <a href="tel:+50255795858" class="ci-value">+502 5579-5858</a>
          </div>
        </div>
        <div class="contact-item">
          <div class="ci-icon"><i class="fa fa-map-marker-alt"></i></div>
          <div class="ci-content">
            <span class="ci-label">Ubicación</span>
            <span class="ci-value">Quetzaltenango, GT</span>
          </div>
        </div>
        <div class="contact-item">
          <div class="ci-icon"><i class="fa fa-calendar"></i></div>
          <div class="ci-content">
            <span class="ci-label">Nacimiento</span>
            <span class="ci-value">10 Dic, 1994</span>
          </div>
        </div>
      </div>

      <!-- Social -->
      <div class="social-block">
        <a href="https://github.com/Ronyib26" target="_blank" rel="noopener" class="social-btn" title="GitHub">
          <i class="fab fa-github"></i>
        </a>
        <a href="https://linkedin.com/in/RonyLopez" target="_blank" rel="noopener" class="social-btn" title="LinkedIn">
          <i class="fab fa-linkedin-in"></i>
        </a>
        <a href="mailto:ronyinvo@icloud.com" class="social-btn" title="Email">
          <i class="fa fa-envelope"></i>
        </a>
      </div>

      <!-- Nav (mobile) -->
      <nav class="sidebar-nav">
        <a href="#about" class="snav-link active" data-section="about">Sobre mí</a>
        <a href="#experience" class="snav-link" data-section="experience">Experiencia</a>
        <a href="#skills" class="snav-link" data-section="skills">Habilidades</a>
        <a href="#projects" class="snav-link" data-section="projects">Proyectos</a>
        <a href="#contact" class="snav-link" data-section="contact">Contacto</a>
      </nav>

    </div>
  </aside>

  <!-- ===== TOPBAR (mobile) ===== -->
  <header class="topbar">
    <div class="topbar-brand">
      <span class="mono-tag">&lt;</span>RL<span class="mono-tag">/&gt;</span>
    </div>
    <nav class="topbar-nav">
      <a href="#about">Sobre mí</a>
      <a href="#experience">Exp.</a>
      <a href="#skills">Skills</a>
      <a href="#projects">Proyectos</a>
      <a href="#contact">Contacto</a>
    </nav>
    <button class="hamburger" id="hamburger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </header>

  <!-- ===== MAIN CONTENT ===== -->
  <main class="main-content">

    <!-- ABOUT -->
    <section id="about" class="page-section active">
      <div class="hero-block fade-in">
        <div class="section-label">// introducción</div>
        <h2 class="hero-heading">
          Hola, soy <span class="accent-text">Rony Lopez</span> 👋
        </h2>
        <p class="hero-sub">Desarrollador Full-Stack con más de 1 año de experiencia construyendo aplicaciones web escalables y robustas. Especializado en React, Node.js, TypeScript, Laravel y arquitecturas cloud.</p>
        <p class="hero-text">
          He trabajado con organizaciones como <strong>FAFG</strong>, <strong>ISACA Guatemala</strong> y <strong>Pastoral Social Cáritas</strong>, entregando sistemas enterprise que soportan 500+ usuarios concurrentes. Enfocado en escribir código limpio, optimizado y crear soluciones de impacto real.
        </p>
        <div class="hero-actions">
          <a href="#projects" class="btn-primary">Ver Proyectos <i class="fa fa-arrow-right"></i></a>
          <a href="#contact" class="btn-outline">Contáctame</a>
        </div>
      </div>

      <!-- Stats -->
      <div class="stats-row">
        <div class="stat-item card fade-in fade-in-delay-1">
          <span class="stat-number accent-text">4+</span>
          <span class="stat-label">Proyectos Enterprise</span>
        </div>
        <div class="stat-item card fade-in fade-in-delay-2">
          <span class="stat-number accent-text">500+</span>
          <span class="stat-label">Usuarios Concurrentes</span>
        </div>
        <div class="stat-item card fade-in fade-in-delay-3">
          <span class="stat-number accent-text">10+</span>
          <span class="stat-label">Tecnologías Dominadas</span>
        </div>
        <div class="stat-item card fade-in fade-in-delay-4">
          <span class="stat-number accent-text">&lt;200ms</span>
          <span class="stat-label">Tiempo de Respuesta</span>
        </div>
      </div>

      <!-- Services -->
      <div class="services-block">
        <div class="section-label">// servicios</div>
        <h3 class="section-title">¿Qué ofrezco?</h3>
        <div class="services-grid">
          <div class="service-card card">
            <div class="sc-icon"><i class="fa fa-code"></i></div>
            <h4>Desarrollo Frontend</h4>
            <p>Interfaces modernas y responsivas con React, TypeScript, Tailwind CSS y Astro. Enfocado en rendimiento y UX.</p>
          </div>
          <div class="service-card card">
            <div class="sc-icon"><i class="fa fa-server"></i></div>
            <h4>Desarrollo Backend</h4>
            <p>APIs RESTful escalables con Node.js, Express y Laravel. Arquitecturas limpias con autenticación JWT y sistemas de colas.</p>
          </div>
          <div class="service-card card">
            <div class="sc-icon"><i class="fa fa-database"></i></div>
            <h4>Bases de Datos</h4>
            <p>Diseño y optimización de bases de datos MySQL, PostgreSQL y Oracle con 25+ índices escalables.</p>
          </div>
          <div class="service-card card">
            <div class="sc-icon"><i class="fab fa-docker"></i></div>
            <h4>DevOps & Cloud</h4>
            <p>Despliegue en AWS, Docker, GitHub Actions. Sistemas production-ready de alta disponibilidad.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- EXPERIENCE -->
    <section id="experience" class="page-section">
      <div class="section-label">// trayectoria</div>
      <h2 class="section-title">Experiencia Técnica</h2>

      <div class="timeline">

        <div class="tl-item">
          <div class="tl-dot"></div>
          <div class="tl-content card">
            <div class="tl-header">
              <div>
                <h3 class="tl-title">Desarrollador Web</h3>
                <span class="tl-company">Cooperativa DEICOM</span>
              </div>
              <div class="tl-stack">
                <span class="tag">Astro</span>
                <span class="tag">Tailwind</span>
                <span class="tag">TypeScript</span>
              </div>
            </div>
            <ul class="tl-list">
              <li>Desarrollé una Landing Page de alto rendimiento logrando tiempos de carga mínimos con arquitectura de componentes reutilizables.</li>
              <li>Implementé identidad visual corporativa precisa basada en manuales de marca.</li>
              <li>Optimicé SEO técnico y responsividad para dispositivos móviles y escritorio.</li>
            </ul>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-dot"></div>
          <div class="tl-content card">
            <div class="tl-header">
              <div>
                <h3 class="tl-title">Sistema de Gestión de Eventos</h3>
                <span class="tl-company">ISACA Guatemala</span>
              </div>
              <div class="tl-stack">
                <span class="tag">Laravel</span>
                <span class="tag">PHP</span>
                <span class="tag">MySQL</span>
                <span class="tag">QR Codes</span>
              </div>
            </div>
            <ul class="tl-list">
              <li>Desarrollé sistema integral con registro público, control de asistencia en tablets y generación automatizada de diplomas.</li>
              <li>Implementé arquitectura multi-guard para autenticación simultánea y sistema de colas para procesamiento asíncrono de emails masivos.</li>
              <li>Optimizaciones de performance que soportaron <strong>500+ usuarios concurrentes</strong> con dashboard de filtros avanzados.</li>
              <li>Integración de QR codes dinámicos, generación automática de PDFs y sistema de emails con reintentos automáticos.</li>
            </ul>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-dot"></div>
          <div class="tl-content card">
            <div class="tl-header">
              <div>
                <h3 class="tl-title">Plataforma de Gestión de Proyectos Sociales</h3>
                <span class="tl-company">Pastoral Social Cáritas</span>
              </div>
              <div class="tl-stack">
                <span class="tag">React</span>
                <span class="tag">Node.js</span>
                <span class="tag">TypeScript</span>
                <span class="tag">PostgreSQL</span>
                <span class="tag">Docker</span>
              </div>
            </div>
            <ul class="tl-list">
              <li>Diseñé e implementé plataforma con Clean Architecture y <strong>65+ endpoints REST</strong> con autenticación JWT.</li>
              <li>Desarrollé sistema de permisos granulares por proyectos, CRUDs completos y vistas Kanban interactivas.</li>
              <li>Integré generación dinámica de PDFs con Puppeteer, dashboard analítico y exportación de reportes.</li>
              <li>Implementé flujo de aprobaciones automatizado con sistema de notificaciones en tiempo real.</li>
            </ul>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-dot"></div>
          <div class="tl-content card">
            <div class="tl-header">
              <div>
                <h3 class="tl-title">Sistema Enterprise de Gestión de Proyectos</h3>
                <span class="tl-company">FAFG</span>
              </div>
              <div class="tl-stack">
                <span class="tag">ScriptCase</span>
                <span class="tag">PHP</span>
                <span class="tag">MySQL</span>
              </div>
            </div>
            <ul class="tl-list">
              <li>Construí sistema con APIs REST con rate limiting y cache multicapa inteligente.</li>
              <li>Desarrollé Kanban enterprise con drag & drop y sistema de documentos con organización automática.</li>
              <li>Implementé <strong>25+ índices escalables</strong> para optimización de queries complejas.</li>
              <li>Sistema production-ready: soporta cientos de usuarios concurrentes con tiempo de respuesta &lt;200ms.</li>
            </ul>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-dot accent-dot"></div>
          <div class="tl-content card">
            <div class="tl-header">
              <div>
                <h3 class="tl-title">Práctica Académica: API REST + Cliente Web</h3>
                <span class="tl-company">Universidad Mariano Gálvez</span>
              </div>
              <div class="tl-stack">
                <span class="tag">Node.js</span>
                <span class="tag">React</span>
                <span class="tag">MySQL</span>
                <span class="tag">AWS</span>
              </div>
            </div>
            <ul class="tl-list">
              <li>Diseñé y desarrollé API RESTful escalable para gestión de empleados y sucursales.</li>
              <li>Construí aplicación web React con interfaz intuitiva y responsive design.</li>
              <li>Desplegué en AWS para alta disponibilidad.</li>
            </ul>
          </div>
        </div>

      </div>

      <!-- Education -->
      <div class="edu-block">
        <div class="section-label" style="margin-top: 60px;">// formación</div>
        <h3 class="section-title">Educación & Certificaciones</h3>
        <div class="edu-grid">
          <div class="edu-item card">
            <div class="edu-icon"><i class="fa fa-graduation-cap"></i></div>
            <div>
              <h4>Ingeniería en Sistemas</h4>
              <p class="edu-org">Universidad Mariano Gálvez de Guatemala</p>
              <span class="tag">2020 — Presente</span>
            </div>
          </div>
          <div class="edu-item card">
            <div class="edu-icon cert-icon"><i class="fa fa-certificate"></i></div>
            <div>
              <h4>Web Dev Essentials</h4>
              <p class="edu-org">Certificación OpenEDG HTML/CSS</p>
              <span class="tag">2025</span>
            </div>
          </div>
          <div class="edu-item card">
            <div class="edu-icon cert-icon"><i class="fa fa-certificate"></i></div>
            <div>
              <h4>JavaScript Essentials</h4>
              <p class="edu-org">Certificación OpenEDG</p>
              <span class="tag">2025</span>
            </div>
          </div>
          <div class="edu-item card">
            <div class="edu-icon cert-icon"><i class="fa fa-network-wired"></i></div>
            <div>
              <h4>CISCO CCNA</h4>
              <p class="edu-org">Introducción a las Redes</p>
              <span class="tag">2025</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SKILLS -->
    <section id="skills" class="page-section">
      <div class="section-label">// tecnologías</div>
      <h2 class="section-title">Stack Técnico</h2>

      <div class="skills-categories">

        <div class="skill-cat card">
          <h3 class="sc-title"><span class="accent-text">01</span> Lenguajes</h3>
          <div class="skill-tags">
            <div class="skill-pill"><i class="fab fa-js"></i> JavaScript</div>
            <div class="skill-pill"><i class="fab fa-js"></i> TypeScript</div>
            <div class="skill-pill"><i class="fab fa-php"></i> PHP</div>
            <div class="skill-pill"><i class="fab fa-python"></i> Python</div>
            <div class="skill-pill"><span class="mono-tag">C++</span></div>
          </div>
        </div>

        <div class="skill-cat card">
          <h3 class="sc-title"><span class="accent-text">02</span> Frontend</h3>
          <div class="skill-tags">
