            <div class="skill-pill">REST APIs</div>
          </div>
        </div>

        <div class="skill-cat card">
          <h3 class="sc-title"><span class="accent-text">04</span> Bases de Datos</h3>
          <div class="skill-tags">
            <div class="skill-pill"><i class="fa fa-database"></i> MySQL</div>
            <div class="skill-pill">PostgreSQL</div>
            <div class="skill-pill">Oracle SQL</div>
